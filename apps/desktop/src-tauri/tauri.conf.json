{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "key-b0x",
  "version": "../package.json",
  "identifier": "com.ari.keyb0x",
  "build": {
    "beforeDevCommand": "npm run dev:renderer",
    "beforeBuildCommand": "npm run build:renderer",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "key-b0x",
        "width": 1180,
        "height": 860,
        "minWidth": 980,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "targets": [
      "appimage",
      "nsis"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU3NTYyQjA1RjkwOURBOTAKUldTUTJnbjVCU3RXVnpEcEJYS0hkK3hvZTQrYjQrcGdPY3lDNGlnck4rdGQrNFlTdDhXVUR2dnoK",
      "endpoints": [
        "https://github.com/arismoko/key-b0x/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
